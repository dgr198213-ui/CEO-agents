## ============================================================================
## CEO-Agents - Variables de Entorno
## ============================================================================
## Copia este archivo a .env y ajusta los valores:
##   cp .env.example .env
## ============================================================================

## ── Base de Datos ─────────────────────────────────────────────────────────
POSTGRES_DB=ceo_agents
POSTGRES_USER=ceo
POSTGRES_PASSWORD=ceo_secret_change_in_production
DB_PORT=5432

# URL completa de conexión (usada por Prisma y el backend)
DATABASE_URL=postgresql://ceo:ceo_secret_change_in_production@localhost:5432/ceo_agents

## ── Backend API ───────────────────────────────────────────────────────────
API_PORT=8080
CEO_LOG_LEVEL=info

## ── LLM Provider ──────────────────────────────────────────────────────────
# Opciones: ollama | openai | anthropic
CEO_LLM_PROVIDER=ollama
CEO_LLM_MODEL=llama3

# URL base de Ollama (si usas LLM local)
CEO_LLM_BASE_URL=http://localhost:11434

# API Keys (solo si usas OpenAI o Anthropic)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

## ── Frontend ──────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080

## ── Ollama ────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434

## ── Adminer (DB GUI, solo desarrollo) ────────────────────────────────────
ADMINER_PORT=8081

## ── Build Info (generado automáticamente en CI) ──────────────────────────
BUILD_DATE=
GIT_SHA=
